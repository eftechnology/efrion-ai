# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Set to "true" to require user confirmation before the AI clicks / types
ENABLE_SAFETY_LOCK=false

# ── Demo access (dynamic token system) ────────────────────────────────────────
# Secret used to sign session cookies (generate a random 32+ char string)
SESSION_SECRET=change-me-to-a-random-32-char-secret

# Secret to protect the admin approve endpoint (/api/admin/approve?secret=...)
ADMIN_SECRET=change-me-to-another-random-secret

# How many hours each approved access token is valid (default: 48)
ACCESS_TOKEN_TTL_HOURS=48

# Base URL of your deployment (used in Telegram approve button URL)
APP_URL=https://ai.efrion.com

# Legacy static credentials (no longer used — kept for reference)
# DEMO_USERNAME=demo
# DEMO_PASSWORD=changeme
# SESSION_TOKEN=changeme_random_secret

# ── SSL / Let's Encrypt ───────────────────────────────────────────────────────
ACME_EMAIL=your@email.com

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 — leave empty to disable
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── SMTP (demo request form emails) ───────────────────────────────────────────
# Any SMTP provider: Gmail, Brevo, Mailgun, Postmark, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=EFRION AI <your@gmail.com>
# Where admin notifications are sent (defaults to hello@efrion.com)
NOTIFY_EMAIL=hello@efrion.com

# ── Umami Analytics (self-hosted) ─────────────────────────────────────────────
# Set the domain where your Umami instance is running
NEXT_PUBLIC_UMAMI_URL=https://umami.yourdomain.com
# Website ID from Umami dashboard → Settings → Websites
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── Cloudflare Turnstile ───────────────────────────────────────────────────────
# Get keys at https://dash.cloudflare.com → Turnstile
# Use sitekey 1x00000000000000000000AA for local testing (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Telegram bot notifications ─────────────────────────────────────────────────
# Create a bot via @BotFather, then get the chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
