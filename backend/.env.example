GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
DATABASE_URL=postgresql://efrion:your_password@localhost:5432/efrion
ENABLE_SAFETY_LOCK=false

# ── Session & access tokens ────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-32-char-secret
ADMIN_SECRET=change-me-to-another-random-secret
ACCESS_TOKEN_TTL_HOURS=48
APP_URL=https://ai.efrion.com
COOKIE_DOMAIN=.efrion.com

# ── SMTP ───────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=EFRION AI <your@gmail.com>
NOTIFY_EMAIL=hello@efrion.com

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Cloudflare Turnstile ───────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=10
